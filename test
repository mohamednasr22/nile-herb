    <!-- ═══ CONTACT ═══ -->
    <script type="text/ng-template" id="tpl/contact.html">
        <section class="main-padding mt-5">
            <div class="container">
                <div class="contact-style py-5">
                    <h4 class="main-title mb-3 mx-auto">Contact Us <span class="line"></span></h4>
                    <div class="row gy-4">
                        <div class="col-lg-6">
                            <div class="contact-form">
                                <div class="main-input sec mb-4">
                                    <input type="text" id="userName" placeholder="Full Name" class="input-me">
                                    <i class="fa-regular fa-user sec-icon"></i>
                                </div>
                                <div class="main-input sec mb-4">
                                    <input type="email" id="email" placeholder="Email Address" class="input-me">
                                    <i class="fa-regular fa-envelope sec-icon"></i>
                                </div>
                                <div class="main-input sec mb-4">
                                    <input type="number" id="phone" placeholder="Phone Number" class="input-me">
                                    <i class="fa-solid fa-phone sec-icon"></i>
                                </div>
                                <div class="main-input mb-4">
                                    <textarea id="message" class="input-me text-area" placeholder="Your message"></textarea>
                                </div>
                                <button ng-click="sendMessage()" type="button" class="main-btn up">Send Now</button>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="row mb-4 gy-3">
                                <div class="col-sm-6">
                                    <div class="contact_box h-100">
                                        <div class="name"><i class="fa-solid fa-clock"></i> Daily</div>
                                        <div class="name">8:00 AM to 10:00 PM</div>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="contact_box h-100">
                                        <div class="name"><i class="fa-solid fa-map-location-dot"></i> Address</div>
                                        <div class="name">Fayoum, Egypt</div>
                                    </div>
                                </div>
                            </div>
                            <iframe loading="lazy" class="map sm"
                                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d6953.3175391407785!2d30.67376083560612!3d29.380278937651752!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14596550600e86f5%3A0xf99d345a34d517d5!5e0!3m2!1sen!2seg!4v1772324364201!5m2!1sen!2seg"
                                width="100%" height="350" style="border:0;" allowfullscreen="" referrerpolicy="no-referrer-when-downgrade">
                            </iframe>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </script>

